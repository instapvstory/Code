{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/ads-demo/layout,_N_T_/ads-demo/page,_N_T_/ads-demo"},"segmentPaths":["/_tree","/_full","/ads-demo/__PAGE__","/ads-demo","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"inter_c15e96cb-module__0bjUvq__variable\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/83afe278b6a6bb3c-s.p.0q-301v4kxxnr.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0-9ip~b3z1.5p.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0yb2wil16uz6h.js\"/><script src=\"/_next/static/chunks/0xp2af3moc5o6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0yoi6g0rt32bk.js\" async=\"\"></script><script src=\"/_next/static/chunks/0o59ac8426icc.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0ijbm49xn0sin.js\" async=\"\"></script><script src=\"/_next/static/chunks/0xfb.q6up~c0w.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/13~0gz0tb5nxm.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>InstaPvStory - Anonymous Instagram Story &amp; Profile Viewer</title><meta name=\"description\" content=\"View Instagram stories, posts, followers and highlights anonymously. No login required.\"/><meta name=\"keywords\" content=\"instagram viewer,anonymous instagram,instagram story viewer,instagram profile viewer\"/><meta property=\"og:title\" content=\"InstaPvStory - Anonymous Instagram Story &amp; Profile Viewer\"/><meta property=\"og:description\" content=\"View Instagram stories, posts, followers and highlights anonymously. No login required.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"InstaPvStory - Anonymous Instagram Story &amp; Profile Viewer\"/><meta name=\"twitter:description\" content=\"View Instagram stories, posts, followers and highlights anonymously. No login required.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div class=\"app-wrapper\" style=\"display:flex;flex-direction:column;min-height:100vh\"><header class=\"Header-module__85i50G__header\"><div class=\"Header-module__85i50G__inner\"><a class=\"Header-module__85i50G__logo\" href=\"/\"><div class=\"Header-module__85i50G__logoIcon\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"8\" r=\"4\" fill=\"white\" opacity=\"0.95\"></circle><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\" stroke=\"white\" stroke-width=\"2.2\" stroke-linecap=\"round\" opacity=\"0.8\"></path></svg></div><span class=\"Header-module__85i50G__logoText\">InstaPvStory</span></a><nav class=\"Header-module__85i50G__nav\"><a class=\"Header-module__85i50G__navLink \" href=\"/\">Home</a><a class=\"Header-module__85i50G__navLink \" href=\"/blog\">Blog</a><a class=\"Header-module__85i50G__navLink \" href=\"/features\">Features</a><a class=\"Header-module__85i50G__navLink \" href=\"/about\">About</a><span class=\"Header-module__85i50G__divider\"></span><button class=\"Header-module__85i50G__loginBtn\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"8\" r=\"4\"></circle><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\"></path></svg>Login</button></nav><button class=\"Header-module__85i50G__hamburger \" aria-label=\"Toggle menu\" aria-expanded=\"false\"><span class=\"Header-module__85i50G__hamburgerLine\"></span><span class=\"Header-module__85i50G__hamburgerLine\"></span><span class=\"Header-module__85i50G__hamburgerLine\"></span></button></div></header><div class=\"Header-module__85i50G__mobileMenu \" role=\"navigation\"><nav class=\"Header-module__85i50G__mobileNavLinks\"><a class=\"Header-module__85i50G__mobileNavLink \" href=\"/\">Home</a><a class=\"Header-module__85i50G__mobileNavLink \" href=\"/blog\">Blog</a><a class=\"Header-module__85i50G__mobileNavLink \" href=\"/features\">Features</a><a class=\"Header-module__85i50G__mobileNavLink \" href=\"/about\">About</a></nav><div class=\"Header-module__85i50G__mobileDivider\"></div><button class=\"Header-module__85i50G__mobileLoginBtn\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"8\" r=\"4\"></circle><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\"></path></svg>Login</button></div><main style=\"flex:1\"><div class=\"container mx-auto px-4 py-8\"><h1 class=\"text-3xl font-bold mb-6\">Ad Inserter Demo</h1><p class=\"text-gray-600 mb-8\">This page demonstrates the ad inserter system for Google AdSense and other ad networks. Ads can be inserted anywhere on the site or within content.</p><div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\"><div class=\"lg:col-span-2\"><div class=\"bg-white rounded-lg shadow p-6 mb-8\"><h2 class=\"text-xl font-semibold mb-4\">Content with Automatic Ad Insertion</h2><div class=\"prose max-w-none\"><div class=\"jsx-93ec87b828956b98 content-with-ads mt-4\"><div class=\"jsx-93ec87b828956b98 mb-8\"><div class=\"jsx-704bf83efe9c34df ad-inserter loading \"><div class=\"jsx-704bf83efe9c34df ad-placeholder\"><div class=\"jsx-704bf83efe9c34df ad-loading-spinner\"></div><span class=\"jsx-704bf83efe9c34df ad-loading-text\">Loading ad...</span></div></div></div><div class=\"jsx-93ec87b828956b98 mt-8\"><div class=\"jsx-704bf83efe9c34df ad-inserter loading \"><div class=\"jsx-704bf83efe9c34df ad-placeholder\"><div class=\"jsx-704bf83efe9c34df ad-loading-spinner\"></div><span class=\"jsx-704bf83efe9c34df ad-loading-text\">Loading ad...</span></div></div></div></div></div></div><div class=\"bg-white rounded-lg shadow p-6\"><h2 class=\"text-xl font-semibold mb-4\">Individual Ad Placements</h2><div class=\"space-y-6\"><div><h3 class=\"font-medium mb-2\">Header Ad</h3><div class=\"jsx-704bf83efe9c34df ad-inserter loading border border-gray-200 rounded p-4\"><div class=\"jsx-704bf83efe9c34df ad-placeholder\"><div class=\"jsx-704bf83efe9c34df ad-loading-spinner\"></div><span class=\"jsx-704bf83efe9c34df ad-loading-text\">Loading ad...</span></div></div></div><div><h3 class=\"font-medium mb-2\">Sidebar Ad</h3><div class=\"jsx-704bf83efe9c34df ad-inserter loading border border-gray-200 rounded p-4\"><div class=\"jsx-704bf83efe9c34df ad-placeholder\"><div class=\"jsx-704bf83efe9c34df ad-loading-spinner\"></div><span class=\"jsx-704bf83efe9c34df ad-loading-text\">Loading ad...</span></div></div></div><div><h3 class=\"font-medium mb-2\">Footer Ad</h3><div class=\"jsx-704bf83efe9c34df ad-inserter loading border border-gray-200 rounded p-4\"><div class=\"jsx-704bf83efe9c34df ad-placeholder\"><div class=\"jsx-704bf83efe9c34df ad-loading-spinner\"></div><span class=\"jsx-704bf83efe9c34df ad-loading-text\">Loading ad...</span></div></div></div></div></div></div><div class=\"lg:col-span-1\"><div class=\"bg-white rounded-lg shadow p-6 sticky top-6\"><h2 class=\"text-xl font-semibold mb-4\">Ad Inserter Documentation</h2><div class=\"space-y-4\"><div><h3 class=\"font-medium text-blue-600\">AdInserter Component</h3><p class=\"text-sm text-gray-600 mt-1\">Use this component to insert ads anywhere in your site:</p><pre class=\"bg-gray-50 p-3 rounded text-xs mt-2 overflow-x-auto\">&lt;AdInserter\n  placement=&quot;after_content&quot;\n  categoryId=&quot;category-uuid&quot;\n  tagIds={[&quot;tag1-uuid&quot;, &quot;tag2-uuid&quot;]}\n  device=&quot;desktop&quot;\n/&gt;</pre></div><div><h3 class=\"font-medium text-blue-600\">ContentAdInserter Component</h3><p class=\"text-sm text-gray-600 mt-1\">Automatically inserts ads between paragraphs in content:</p><pre class=\"bg-gray-50 p-3 rounded text-xs mt-2 overflow-x-auto\">&lt;ContentAdInserter\n  content={htmlContent}\n  categoryId=&quot;category-uuid&quot;\n  adFrequency={3}\n/&gt;</pre></div><div><h3 class=\"font-medium text-blue-600\">Available Placements</h3><ul class=\"text-sm text-gray-600 mt-1 space-y-1\"><li>• header - Site header</li><li>• footer - Site footer</li><li>• sidebar - Sidebar area</li><li>• before_content - Before article</li><li>• after_content - After article</li><li>• after_p1, after_p2, etc. - After specific paragraphs</li><li>• between_blocks - Between content blocks</li></ul></div><div><h3 class=\"font-medium text-blue-600\">Ad Types Supported</h3><ul class=\"text-sm text-gray-600 mt-1 space-y-1\"><li>• adsense - Google AdSense</li><li>• custom - Custom HTML ads</li><li>• html - HTML banner ads</li><li>• script - JavaScript-based ads</li></ul></div><div class=\"pt-4 border-t\"><h3 class=\"font-medium text-green-600\">Admin Panel</h3><p class=\"text-sm text-gray-600 mt-1\">Manage ads from the admin dashboard at <code>/admin/ads</code></p><a href=\"/admin/ads\" class=\"inline-block mt-2 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm\">Go to Ad Management</a></div></div></div></div></div><div class=\"mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6\"><h3 class=\"text-lg font-semibold text-blue-800 mb-2\">How It Works</h3><ul class=\"text-blue-700 space-y-2\"><li>• Ads are stored in the database with targeting options (category, tags, devices)</li><li>• The AdInserter component fetches relevant ads based on placement and context</li><li>• Ad views and clicks are automatically tracked for analytics</li><li>• Ads can be scheduled with start/end dates and impression limits</li><li>• Multiple ad networks supported (AdSense, custom HTML, scripts, etc.)</li></ul></div></div><!--$--><!--/$--></main><footer class=\"Footer-module__hP-FLq__footer\"><div class=\"container\"><div class=\"Footer-module__hP-FLq__content\"><div class=\"Footer-module__hP-FLq__brand\"><div class=\"Footer-module__hP-FLq__brandTitle\"><div class=\"Footer-module__hP-FLq__logoIcon\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"8\" r=\"4\" fill=\"white\" opacity=\"0.95\"></circle><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\" stroke=\"white\" stroke-width=\"2.2\" stroke-linecap=\"round\" opacity=\"0.8\"></path></svg></div><h3 style=\"color:#ffffff;margin:0\">InstaPvStory</h3></div><p class=\"text-small\">Anonymous Instagram story and highlight viewer.</p></div><div class=\"Footer-module__hP-FLq__links\"><div class=\"Footer-module__hP-FLq__group\"><h4>Company</h4><a class=\"text-small\" href=\"/about\">About Us</a><a class=\"text-small\" href=\"/features\">Features</a><a class=\"text-small\" href=\"/blog\">Blog</a></div><div class=\"Footer-module__hP-FLq__group\"><h4>Legal</h4><a class=\"text-small\" href=\"/terms\">Terms of Service</a><a class=\"text-small\" href=\"/privacy\">Privacy Policy</a><a class=\"text-small\" href=\"/disclaimer\">Disclaimer</a></div><div class=\"Footer-module__hP-FLq__group\"><h4>Support</h4><a class=\"text-small\" href=\"/contact\">Contact Us</a><a class=\"text-small\" href=\"/#faq\">FAQ</a></div></div></div><div class=\"Footer-module__hP-FLq__bottom\"><p class=\"text-small\">© <!-- -->2024<!-- --> InstaPvStory. All rights reserved.</p></div></div></footer></div><script src=\"/_next/static/chunks/0yb2wil16uz6h.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[68504,[\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n5:I[89696,[\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/13~0gz0tb5nxm.js\\\"],\\\"default\\\"]\\ne:I[68027,[\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0-9ip~b3z1.5p.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/83afe278b6a6bb3c-s.p.0q-301v4kxxnr.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n6:T73d,\"])</script><script>self.__next_f.push([1,\"\\n    \\u003ch1\\u003eUnderstanding Modern Web Development\\u003c/h1\\u003e\\n    \\n    \\u003cp\\u003eWeb development has evolved significantly over the past decade. From simple static HTML pages to complex single-page applications, the landscape continues to change rapidly.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eOne of the most significant shifts has been the move towards component-based architectures. Frameworks like React, Vue, and Angular have revolutionized how we build user interfaces.\\u003c/p\\u003e\\n    \\n    \\u003ch2\\u003eThe Rise of JavaScript Frameworks\\u003c/h2\\u003e\\n    \\n    \\u003cp\\u003eJavaScript frameworks have become essential tools for modern web developers. They provide structure, efficiency, and maintainability to complex applications.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eReact, developed by Facebook, introduced the concept of virtual DOM and component reusability. This approach has been widely adopted across the industry.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eVue.js offers a progressive framework that can be adopted incrementally. Its gentle learning curve makes it popular among beginners and experts alike.\\u003c/p\\u003e\\n    \\n    \\u003ch2\\u003eServer-Side Rendering and Next.js\\u003c/h2\\u003e\\n    \\n    \\u003cp\\u003eNext.js has emerged as a leading framework for React applications, offering server-side rendering, static site generation, and API routes out of the box.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eThis approach improves SEO performance and provides better user experience through faster initial page loads.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eThe framework's file-based routing system simplifies navigation and makes code organization more intuitive.\\u003c/p\\u003e\\n    \\n    \\u003ch2\\u003eConclusion\\u003c/h2\\u003e\\n    \\n    \\u003cp\\u003eModern web development continues to evolve, with new tools and techniques emerging regularly. Staying current with these changes is essential for any web developer.\\u003c/p\\u003e\\n    \\n    \\u003cp\\u003eBy understanding the core principles and keeping up with industry trends, developers can build better, faster, and more maintainable web applications.\\u003c/p\\u003e\\n  \"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"ads-demo\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"ads-demo\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]},\\\"$undefined\\\",\\\"$undefined\\\",16],[[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[[\\\"$\\\",\\\"link\\\",\\\"0\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/chunks/0-9ip~b3z1.5p.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"script\\\",\\\"script-0\\\",{\\\"src\\\":\\\"/_next/static/chunks/0xfb.q6up~c0w.js\\\",\\\"async\\\":true,\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"script\\\",\\\"script-1\\\",{\\\"src\\\":\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"async\\\":true,\\\"nonce\\\":\\\"$undefined\\\"}]],[\\\"$\\\",\\\"html\\\",null,{\\\"lang\\\":\\\"en\\\",\\\"className\\\":\\\"inter_c15e96cb-module__0bjUvq__variable\\\",\\\"children\\\":[\\\"$\\\",\\\"body\\\